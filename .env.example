# NeighborDogs - copy to .env.local for local development.
# Use test-mode Stripe keys locally. Do not commit real secrets.

# Supabase - client browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase - server API routes, webhooks, operator slug and price resolution
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe - territory subscription and Operator Commerce / Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_TERRITORY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App origin for Checkout success/cancel and Connect onboarding return URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional - Census API for territory preview higher rate limit
# CENSUS_API_KEY=

# Optional - test mode, non-production only
# NEXT_PUBLIC_ENABLE_TEST_MODE=true
# TEST_MODE_PIN=
